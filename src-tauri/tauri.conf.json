{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "MangaMaker",
  "version": "0.1.0",
  "identifier": "com.example.mangamaker",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173"
  },
  "app": {
    "windows": [
      {
        "title": "MangaMaker",
        "width": 1440,
        "height": 960
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all"
  }
}
