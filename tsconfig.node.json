{
  "compilerOptions": {
    "composite": true,
    "skipLibCheck": true,
    "target": "ES2021",
    "lib": ["ES2021"],
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "allowSyntheticDefaultImports": true,
    "noEmit": true
  },
  "include": [
    "vite.config.ts",
    "playwright.config.ts",
    "src/agent/documentSchema.ts",
    "src/agent/openRouterProviderRouting.ts",
    "src/agent/openRouterResponse.ts",
    "src/agent/roles.ts",
    "src/agent/systemPrompt.ts",
    "src/agent/toolLimits.ts"
  ]
}
